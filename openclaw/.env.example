# Public AdamHUB URL if OpenClaw is external.
# Docker-internal URL is also valid when both services share the same network.
# Do not use 127.0.0.1 unless OpenClaw runs in the same container namespace.
ADAMHUB_API_URL=https://adamhub.example.com
ADAMHUB_API_KEY=change-me-to-the-same-secret-as-backend
